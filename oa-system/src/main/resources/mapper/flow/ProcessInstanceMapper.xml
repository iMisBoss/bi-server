<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.newtouch.oa.mapper.flow.ProcessInstanceMapper">

    <resultMap id="BaseResultMap" type="com.newtouch.oa.entity.flow.ProcessInstance">
        <id column="id" property="id"/>
        <result column="flowable_instance_id" property="flowableInstanceId"/>
        <result column="process_def_id" property="processDefId"/>
        <result column="business_key" property="businessKey"/>
        <result column="title" property="title"/>
        <result column="applicant_id" property="applicantId"/>
        <result column="applicant_name" property="applicantName"/>
        <result column="department" property="department"/>
        <result column="status" property="status"/>
        <result column="start_time" property="startTime"/>
        <result column="end_time" property="endTime"/>
        <result column="duration" property="duration"/>
        <result column="variables" property="variables"/>
        <result column="create_by" property="createBy"/>
        <result column="create_time" property="createTime"/>
        <result column="update_by" property="updateBy"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, flowable_instance_id, process_def_id, business_key, title, applicant_id,
        applicant_name, department, status, start_time, end_time, duration, variables,
        create_by, create_time, update_by, update_time, deleted
    </sql>

    <select id="selectByFlowableInstanceId" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM flow_process_instance
        WHERE flowable_instance_id = #{flowableInstanceId} AND deleted = 0
    </select>
</mapper>
